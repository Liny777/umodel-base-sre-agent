# ============================================================
#  umodel-base-sre-agent — Environment Configuration (D1)
# ============================================================
#  D1 范围: 单 Agent + 47 SKILL.md + 内网 LLM gateway
#  D3 起会加 MCP server 配置;D4 加 UMODEL_BASE_URL
# ============================================================

# ===== LLM (D1: 通过 POST /credentials 注入,这里只是默认值) =====
# 内网 OpenAI-compatible gateway(填你公司的地址)
LLM_BASE_URL=http://your-internal-llm-gateway/v1
LLM_API_KEY=your-key-here
LLM_MODEL=gpt-4.1                 # 默认模型,Agent 创建时可覆盖

# ===== AgentScope 运行时 (D1) =====
REDIS_HOST=localhost
REDIS_PORT=6379
WORKSPACE_BASEDIR=./workspaces    # per-session 工作空间根目录
SKILLS_DIR=./skills               # SKILL.md 加载根目录(symlink → IncidentFox 47 skills)

# ===== HTTP 服务 (D1) =====
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_RELOAD=true               # 开发期热重载

# ===== umodel 对接 (D4 启用) =====
# UMODEL_BASE_URL=http://127.0.0.1:8080
# UMODEL_API_KEY=
# UMODEL_WORKSPACE=otel-demo-persistent

# ===== MCP servers (D3 启用) =====
# 配置形式见 src/sre_agent/mcp_config.py(D3 实现)

# ===== 可选: 观测 (P5) =====
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

# ===== 可选: 数据库 (P3 启用) =====
# DATABASE_URL=postgresql://sre:sre@localhost:5432/umodel_sre
